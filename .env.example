# Job Seeker AI Toolkit — Environment Variables
# Copy this file to .env and fill in your values.
# Only ANTHROPIC_API_KEY is required for basic use.

# ── Required ───────────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here


# ── Optional: Email Digest (GitHub Actions automation) ─────────────────────────
# Required only if you want automated daily job digests sent to your inbox.
# Uses Resend (https://resend.com — free tier: 100 emails/day).

RESEND_API_KEY=
DIGEST_FROM_EMAIL=digest@yourdomain.com
DIGEST_TO_EMAIL=you@example.com


# ── Optional: Firecrawl (career page scraping for JS-heavy sites) ─────────────
# Required for Mode 2 (career pages) to work on Ashby, Lever, Greenhouse, Workday.
# Without this, Mode 2 falls back to trafilatura (works for static pages only).
# Get your key at https://firecrawl.dev — free tier: 500 pages/month.

FIRECRAWL_API_KEY=


# ── Optional: Apify (LinkedIn job search) ─────────────────────────────────────
# Required for Mode 5 (/find-jobs --apify). Authenticated LinkedIn search via
# proxy-backed actors. Get your token at https://apify.com — free tier available.
# Note: using Apify to scrape LinkedIn may conflict with LinkedIn's ToS.

APIFY_TOKEN=


# ── Optional: Gmail Integration ────────────────────────────────────────────────
# Required only if you want /track-application to auto-detect replies in Gmail.
# Setup guide: see README.md → Gmail Setup section.

GMAIL_CREDENTIALS_PATH=config/gmail_credentials.json
GMAIL_TOKEN_PATH=config/gmail_token.json


# ── Optional: Google Drive Backup ──────────────────────────────────────────────
# Required only if you want prepared documents auto-saved to Google Drive.

GOOGLE_DRIVE_FOLDER_ID=


# ── Internal Paths (defaults work for most users) ──────────────────────────────
# Override only if you've moved files from their default locations.

# CONFIG_DIR=config
# DATA_DIR=data
# COACHING_STATE_PATH=coaching_state.md
