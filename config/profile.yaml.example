# Job Seeker AI Toolkit — User Profile Example
# ─────────────────────────────────────────────
# This file shows what /setup creates.
# Do not edit this file — run /setup to build or update your actual profile.yaml.
# Your real profile.yaml is gitignored and stays on your machine only.

schema_version: "1.0"

# ── Identity ─────────────────────────────────────────────────────────────────
name: "Alex Chen"
target_roles:
  - "Product Manager"
  - "Senior Product Manager"
seniority: "mid-career"                 # e.g. junior, mid-career, senior, director
location: "Singapore"
preferred_work_arrangement: "hybrid or remote"
experience_years: 6

# ── Positioning ──────────────────────────────────────────────────────────────
# Extracted from your resume by /setup. Used in scoring and all coaching outputs.
key_skills:
  - "Product roadmap and prioritisation"
  - "Cross-functional stakeholder management"
  - "Data analysis and SQL"
  - "Agile / Scrum"
  - "User research and usability testing"
  - "B2B SaaS"

positioning_strengths:
  - "Led 0→1 launch of a payments feature at a Series B fintech — $2M ARR in year one"
  - "Strong data instincts — built dashboards that became team-wide standards"
  - "Engineering background gives credibility with technical teams"

known_concerns:
  - "No enterprise (>500 seat) experience — mostly SMB and mid-market"
  - "Short tenure at second company (14 months) — left due to acquisition"

certifications: []   # Only list what you actually have — used for anti-fabrication checks
  # - "AWS Certified Cloud Practitioner"
  # - "Google Analytics Certified"

# ── Company Preferences ───────────────────────────────────────────────────────
# Drives the preference_fit score. Plain English descriptions — no codes or IDs.
company_preferences:
  minimum_bar:
    - "Series A or later — needs some product-market fit traction"
    - "Engineering team of at least 10"
    - "Has a product function (not just engineering-led)"

  ideal_signals:
    - "AI-native or AI-serious — not just bolting on a chatbot"
    - "B2B SaaS with a clear ICP"
    - "Founder-led but with professional leadership team forming"
    - "Remote-first or strong hybrid culture"

  nice_to_have:
    - "Southeast Asia focus or regional expansion play"
    - "Fintech, HR tech, or developer tools"

  deal_breakers:
    - "Agencies or consulting — needs to own a product, not client work"
    - "Roles with no engineering budget (PM without engineers)"
    - "Fully onsite only"

# ── Scoring Configuration ─────────────────────────────────────────────────────
# Controls when tailored documents and coaching notes are generated.
# Adjust thresholds if you want more or fewer listings flagged for action.
scoring:
  # Dual-axis thresholds: BOTH skills_fit AND preference_fit must be met.
  # Use a single int (applies to both axes) or a dict with skills_fit_min + preference_fit_min.
  threshold_for_preparation:     # to generate tailored resume + cover letter
    skills_fit_min: 6
    preference_fit_min: 7
  threshold_for_coaching:        # to add entry to coaching_state.md
    skills_fit_min: 6
    preference_fit_min: 7
  glassdoor_enrich_limit: 5      # Max listings to enrich with Glassdoor data per search run

  dimensions:
    skills_fit:
      description: "Score 0-10: How well can this candidate do this job?"
      components:
        role_match: "0-4 points: Does the role match target function and seniority?"
        skills_alignment: "0-4 points: How many key skills appear in JD requirements?"
        location_fit: "0-2 points: Does location/remote policy match candidate needs?"
      deal_breakers:
        - "Requires C++, embedded systems, or hardware engineering: cap skills_fit at 3"

    preference_fit:
      description: "Score 0-10: How well does this company/role match what the candidate wants?"
      components:
        ai_seriousness: "0-3 points: Is AI genuinely core to the product?"
        role_scope: "0-3 points: Does the role have real ownership and building opportunity?"
        company_fit: "0-2 points: Does company stage/type match preferences?"
        autonomy_signal: "0-2 points: Does the JD signal autonomy and low bureaucracy?"
      deal_breakers:
        - "Agency or consulting work: cap preference_fit at 2"

# ── Feedback Style ────────────────────────────────────────────────────────────
# 1 = gentlest framing, 5 = most direct (default). Scores never change — only tone.
feedback_directness: 4

# ── Document Paths ────────────────────────────────────────────────────────────
resume_path: "config/resume_base.md"
cover_letter_path: "config/cover_letter_base.md"

# ── Search Configuration ──────────────────────────────────────────────────────
search:
  max_age_days: 30             # Filter out listings older than this
  additional_keywords:         # Extra keywords added to search queries
    - "product-led growth"
    - "B2B SaaS"

# ── LinkedIn (optional — only needed for /find-jobs --apify) ──────────────────
# Set up automatically when you first run /find-jobs --apify.
# Do NOT pre-fill user_agent — leave this section out entirely until Mode 5 prompts you.
# linkedin:
#   user_agent: "Mozilla/5.0 ..."   # Your browser's user agent string
